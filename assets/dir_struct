engagements/
└── target_com/
    ├── scope.txt                              # apex domains, one per line
    ├── asns.txt                               # discovered ASN numbers
    ├── ip_ranges.txt                          # CIDR blocks from ASN lookup
    │
    ├── phase1_passive/
    │   ├── cloud_hosts.txt                    # extracted from kaeferjaeger cert dump
    │   ├── censys_hosts.txt                   # hosts and open ports from Censys API
    │   ├── smap_results.txt                   # Shodan-backed passive port data (no packets sent)
    │   └── sonar_rdns.txt                     # Rapid7 RDNS matches for ip_ranges.txt
    │                                          # key value: reveals IPs with no current DNS record
    │
    ├── phase2_subdomains/
    │   ├── subfinder_raw.txt                  # per-tool output kept for auditing
    │   ├── amass_raw.txt
    │   ├── chaos_raw.txt
    │   ├── subdomains_raw.txt                 # cat *_raw.txt | sort -u (merged)
    │   ├── permutations.txt                   # altdns / dnsgen output
    │   └── subdomains_resolved.txt            # only hosts that resolved via dnsx
    │
    ├── phase2.1_network_active/               # optional — only when program explicitly permits scanning
    │   ├── asnmap_ranges.txt                  # expanded CIDRs derived from asns.txt
    │   ├── naabu_live_ports.txt               # IP:port pairs that responded (web-focused ports)
    │   │                                      # recommended: 80,443,8080,8443,4443,8888,9000
    │   ├── nmap_banners.txt                   # service and version banners from nmap -sV
    │   └── ip_no_dns.txt                      # IPs that responded but have no entry in
    │                                          # subdomains_resolved.txt — your forgotten
    │                                          # staging environment candidates
    │                                          # produced with:
    │                                          # comm -23 \
    │                                          #   <(awk -F: '{print $1}' naabu_live_ports.txt | sort -u) \
    │                                          #   <(awk '{print $2}' ../phase2_subdomains/subdomains_resolved.txt | sort -u)
    │
    ├── phase3_surface/
    │   ├── live_hosts.csv                     # httpx output: status, title, tech, asn, server
    │   │                                      # fed by BOTH subdomains_resolved.txt (phase 2)
    │   │                                      # AND ip_no_dns.txt (phase 2.1) — convergence point
    │   └── screenshots/                       # gowitness output directory
    │
    ├── priority_hosts.txt                     # manually curated after checkpoint 1
    │                                          # checkpoint: review screenshots, annotate live_hosts.csv
    │                                          # with priority (high / medium / skip)
