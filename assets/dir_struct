    │   ├── js_cache/                          # locally downloaded JS bundle files
    │   │   └── <md5hash>.js                   # named by hash to avoid collisions
    │   ├── js_endpoints.txt                   # linkfinder + collector.py extracted endpoints
    │   └── all_urls.txt                       # single source of truth — everything merged via anew
    │
    ├── phase5_params/
    │   ├── paramspider_raw.txt                # wayback-sourced param URLs (passive)
